# Server
PORT=3000
DEFAULT_DIRECTION=EN_TO_ZH

# Google credentials (service account JSON path)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Translation settings
# If TRANSLATION_PROJECT_ID is empty, GOOGLE_CLOUD_PROJECT is used.
TRANSLATION_PROJECT_ID=
# Use 'global' for plain translation; switch to a region (e.g. us-central1)
# if you provision a Cloud Translation glossary via scripts/sync-cloud-glossary.sh.
TRANSLATION_LOCATION=global
# Optional: Cloud Translation glossary id (must already exist; provisioned by the sync script)
TRANSLATION_GLOSSARY_ID=
# Optional: override the GCS bucket name the sync script uses
# (defaults to verba-bridge-glossary-<project>)
GLOSSARY_BUCKET=

# ASR settings
ASR_SAMPLE_RATE_HERTZ=16000
ASR_INTERIM_RESULTS=true
# Optional: specific input device or recorder program
# RECORD_PROGRAM supported values: sox, rec, arecord
# Leave empty to auto-detect from PATH.
AUDIO_DEVICE=
RECORD_PROGRAM=

# Glossary file
GLOSSARY_PATH=config/glossary.csv

# Transcript recording
# Each session writes a plain-text transcript here. Directory is created on demand.
RECORDING_DIR=recordings
